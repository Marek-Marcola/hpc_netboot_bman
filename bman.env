VERSION_ENV="260524"

# set variables in \$HOME/.bman.env or cli:
#  - os_cid (Cluster ID)
#  - os_sid (System ID)

if [[ "$os_sid" = "rocky-9.7" ]]; then
  : ${os_dist:=rocky}
  : ${os_ver:=9.7}
  : ${os_cfg:=r9-base,r9-auth,r9-lfs,r9-hpc,r9-virt}
  INFO="Rocky 9.7"
fi

